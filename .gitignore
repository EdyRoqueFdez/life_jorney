# =============================================================================
# life_jorney — .gitignore
# Stack: Python/Django · React/TypeScript · Flutter/Dart · Docker
# =============================================================================

# =============================================================================
# SECRETS & CREDENTIALS — never commit these
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/
service_account*.json

# =============================================================================
# PYTHON / DJANGO
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/
.installed.cfg

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
/staticfiles/
/mediafiles/

# Coverage
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
nosetests.xml

# pytest
.pytest_cache/
pytest_cache/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# =============================================================================
# REACT / TYPESCRIPT / NODE
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build output
/frontend/build/
/frontend/dist/
/frontend/.next/
/frontend/out/

# Cache
.eslintcache
.stylelintcache
*.tsbuildinfo

# Testing
/frontend/coverage/

# =============================================================================
# FLUTTER / DART
# =============================================================================
# Build
/mobile/.dart_tool/
/mobile/build/

# Android
/mobile/android/.gradle/
/mobile/android/local.properties
/mobile/android/app/debug/
/mobile/android/app/profile/
/mobile/android/app/release/
/mobile/android/key.properties
*.jks
*.keystore

# iOS
/mobile/ios/Pods/
/mobile/ios/.symlinks/
/mobile/ios/Flutter/flutter_export_environment.sh
/mobile/ios/Flutter/App.framework
/mobile/ios/Flutter/Flutter.framework
/mobile/ios/Flutter/Flutter.podspec
/mobile/ios/Flutter/Generated.xcconfig
/mobile/ios/Runner.xcworkspace/
*.mode1v3
*.mode2v3
*.moved-aside
*.pbxuser
!default.pbxuser
*.perspectivev3
!default.perspectivev3
xcuserdata/

# Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock

# =============================================================================
# DOCKER
# =============================================================================
.docker/
docker-compose.override.yml

# =============================================================================
# DATABASES (local dev)
# =============================================================================
*.sqlite
*.sqlite3
*.db
postgres-data/
redis-data/
minio-data/

# =============================================================================
# EDITORS & IDEs
# =============================================================================

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (PyCharm, IntelliJ, Android Studio)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

# =============================================================================
# UPLOADS & GENERATED FILES
# =============================================================================
/uploads/
/media/
*.dicom
*.dcm

# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*

# =============================================================================
# MISC
# =============================================================================
*.bak
*.tmp
*.orig
.cache/
.temp/
tmp/
temp/
